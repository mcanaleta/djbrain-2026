{
  "extends": "./tsconfig.base.json",
  "include": ["src/web/src/env.d.ts", "src/web/src/**/*", "src/shared/**/*"],
  "exclude": ["src/shared/**/*.test.ts"],
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@web/*": ["src/web/src/*"]
    }
  }
}
