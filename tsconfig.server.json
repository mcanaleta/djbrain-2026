{
  "extends": "./tsconfig.base.json",
  "include": [
    "vite.config.ts",
    "src/server/**/*",
    "src/backend/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": false,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowImportingTsExtensions": true
  }
}
