{
  "extends": "./tsconfig.base.json",
  "include": [
    "vite.config.ts",
    "src/server/**/*",
    "src/main/settings-store.ts",
    "src/main/collection-service.ts",
    "src/main/online-search-service.ts",
    "src/main/grok-search-service.ts",
    "src/main/slskd-service.ts",
    "src/main/discogs-match-service.ts",
    "src/main/tagger-service.ts",
    "src/main/import-service.ts",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": false,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowImportingTsExtensions": true
  }
}
