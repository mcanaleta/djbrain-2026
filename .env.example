# DJBrain Docker environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or generate from an existing settings.json:
#   npx tsx scripts/export-env.ts /path/to/settings.json > .env

# Music library path (host path is mapped via volumes in docker-compose.yml)
DJBRAIN_MUSIC_FOLDER_PATH=/music
DJBRAIN_SONGS_FOLDER_PATH=songs
DJBRAIN_DOWNLOAD_FOLDER_PATHS=downloads

# Soulseek daemon
DJBRAIN_SLSKD_BASE_URL=http://slskd:5030
DJBRAIN_SLSKD_API_KEY=

# API keys
DJBRAIN_DISCOGS_USER_TOKEN=
DJBRAIN_GROK_API_KEY=
DJBRAIN_SERPER_API_KEY=
DJBRAIN_YOUTUBE_API_KEY=
